generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  jobs         Job[]
  applications Application[]
}

model Job {
  id           String        @id @default(cuid())
  companyName  String
  position     String
  type         JobType
  location     String
  description  String?
  salary       String?
  requirements String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  postedBy     User          @relation(fields: [postedById], references: [id])
  postedById   String
  applications Application[]

  @@index([postedById])
}

model Application {
  id         String            @id @default(cuid())
  user       User              @relation(fields: [userId], references: [id])
  userId     String
  job        Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId      String
  status     ApplicationStatus @default(PENDING)
  reviewedAt DateTime?
  notes      String?
  createdAt  DateTime          @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
}

enum Role {
  USER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  INTERVIEW
  OFFER
  REJECTED
}
