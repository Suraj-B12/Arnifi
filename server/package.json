{
  "name": "arnifi-server",
  "version": "1.0.0",
  "description": "Arnifi Job Portal - Backend API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
